OPENAI_API_KEY=sk-your-key-here
# API 根路径（示例为 v3）；不要写完整 .../chat/completions
OPENAI_BASE_URL=https://api.example.com/v3
OPENAI_MODEL=gpt-4o-mini

# Learning MD：Markdown 根目录（可选；默认 backend/docs_md）
# MD_DOCS_ROOT=E:/notes/learning-md

# PostgreSQL（Learning Map 案例与图谱快照）
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/learning_map

# Alembic：在 backend 目录执行迁移（应用启动时也会自动 alembic upgrade head）
# alembic upgrade head
# 若数据库曾用旧版 create_all 建表且结构与当前一致，可标记版本而不再执行 DDL：
# alembic stamp 868c5acd2d34

# LangSmith / LangChain 可观测性（可选）
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT="learning-map"

